    "@dnd-kit/utilities": "^3.2.2",
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/leaflet": "^1.9.21",
    "@vercel/analytics": "^2.0.1",
    "antd": "^6.3.4",
    "date-fns": "^4.1.0",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "next": "16.1.7",
